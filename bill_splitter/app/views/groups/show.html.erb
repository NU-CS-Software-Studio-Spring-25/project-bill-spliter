<div class="container mt-5">
  <!-- Header Section -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="text-primary fw-bold display-5 mb-1">
        <i class="bi bi-people-fill me-2"></i><%= @group.group_name %>
      </h1>
      <p class="text-muted fs-5">Group Details</p>
    </div>
    <div>
      <%= link_to new_expense_path(group_id: @group.id), class: 'btn btn-primary btn-lg me-2' do %>
        <i class="bi bi-plus-circle me-1"></i>Add Expense
      <% end %>
      <%= link_to expenses_path, class: 'btn btn-outline-secondary btn-lg' do %>
        <i class="bi bi-house-door me-1"></i>Home
      <% end %>
    </div>
  </div>

  <div class="row">
    <!-- Members Section -->
    <div class="col-md-4 mb-4">
      <div class="card shadow-lg border-0 h-100">
        <div class="card-header bg-light border-bottom">
          <h4 class="mb-0 text-muted">
            <i class="bi bi-person-lines-fill me-1"></i>Members
          </h4>
        </div>
        <div class="card-body">
          <ul class="list-group list-group-flush">
            <% @members.each do |member| %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><i class="bi bi-person me-1 text-primary"></i><%= member.name %></span>
                <span class="badge bg-primary rounded-pill">Member</span>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>

    <!-- Expenses Section -->
    <div class="col-md-8">
      <div class="card shadow-lg border-0">
        <div class="card-header bg-light border-bottom">
          <h4 class="mb-0 text-muted">
            <i class="bi bi-cash-stack me-1"></i>Expenses
          </h4>
        </div>
        <div class="card-body">
          <% if @expenses.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead class="table-light">
                  <tr>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Added By</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @expenses.each do |expense| %>
                    <tr>
                      <td>
                        <%= link_to expense.description, expense_path(expense),
                          class: 'text-decoration-none fw-semibold text-dark' %>
                      </td>
                      <td><span class="text-success"><%= number_to_currency(expense.total_amount) %></span></td>
                      <td>
                        <span class="badge bg-secondary"><%= expense.added_by_user&.name || 'Unknown' %></span>
                      </td>
                      <td class="text-end">
                        <div class="btn-group btn-group-sm">
                          <%= link_to 'View', expense_path(expense), class: 'btn btn-outline-primary' %>
                          <%= button_to 'Delete', expense_path(expense),
                              method: :delete,
                              class: 'btn btn-outline-danger',
                              data: { turbo_confirm: 'Are you sure you want to delete this expense?' } %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="alert alert-warning d-flex align-items-center" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i>
              No expenses recorded in this group yet.
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
