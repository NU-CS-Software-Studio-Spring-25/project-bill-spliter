<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-primary fw-bold display-6">
      <i class="bi bi-plus-circle me-2"></i>New Expense
    </h1>
    <%= link_to expenses_path, class: 'btn btn-outline-secondary btn-lg' do %>
      <i class="bi bi-arrow-left-circle me-1"></i>Back to Expenses
    <% end %>
  </div>

  <div class="card border-0 shadow-lg">
    <div class="card-header bg-light border-bottom py-3">
      <h5 class="mb-0 text-muted"><i class="bi bi-pencil-square me-1"></i> Fill out the expense details</h5>
    </div>
    <div class="card-body">
      <%= form_with(model: @expense, local: true, html: { class: 'needs-validation', novalidate: true }) do |form| %>
        <div class="row mb-3">
          <div class="col-md-6">
            <div class="form-floating mb-3">
              <%= form.text_field :description, class: 'form-control', placeholder: ' ', required: true %>
              <%= form.label :description, class: 'form-label' %>
            </div>
          </div>

          <div class="col-md-6">
            <div class="form-floating mb-3">
              <%= form.number_field :total_amount, class: 'form-control', placeholder: ' ', step: '0.01', required: true %>
              <%= form.label :total_amount, class: 'form-label' %>
            </div>
          </div>
        </div>

        <div class="row mb-3">
          <div class="col-md-6">
            <div class="form-floating mb-3">
              <% if @groups.present? %>
                <%= form.collection_select :group_id, @groups, :id, :group_name,
                    { prompt: "Select a Group" },
                    { class: 'form-select', required: true } %>
              <% else %>
                <div class="alert alert-warning">
                  <i class="bi bi-exclamation-circle-fill me-1"></i>No groups available. Please create a group first.
                </div>
              <% end %>
              <%= form.label :group_id, class: 'form-label' %>
            </div>
          </div>

          <div class="col-md-6">
            <div class="form-floating mb-3">
              <% if @users.present? %>
                <%= form.select :added_by, @users.map { |user| [user.name, user.id] }, 
                    { prompt: "Select a User" }, 
                    { class: 'form-select', required: true } %>
              <% else %>
                <div class="alert alert-warning">
                  <i class="bi bi-exclamation-circle-fill me-1"></i>No users available. Please create a user first.
                </div>
              <% end %>
              <%= form.label :added_by, class: 'form-label' %>
            </div>
          </div>
        </div>

        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
          <%= form.submit 'Add Expense', class: 'btn btn-primary btn-lg px-4' %>
        </div>

        <% if @expense.errors.any? %>
          <div class="alert alert-danger mt-4">
            <h5 class="alert-heading mb-2">
              <i class="bi bi-exclamation-triangle-fill me-2"></i>There were some errors with your submission: >
            </h5>
              <ul class="mb-0 ps-3">
                <% @expense.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>